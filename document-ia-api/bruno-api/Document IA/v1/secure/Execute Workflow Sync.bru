meta {
  name: Execute Workflow Sync
  type: http
  seq: 2
}

post {
  url: {{server}}api/v1/workflows/{{workflow_id}}/execute-sync
  body: multipartForm
  auth: inherit
}

body:multipart-form {
  metadata: {"test":"test"} @contentType(String)
  file: @file(/Users/nsagon/Projects/files/carte d'identité recto.pdf)
  ~extraction-parameters: {"document-type": "cni"}
  ~classification-parameters: {}
}

vars:pre-request {
  workflow_id: poc-embedding-dataset-cni
}

settings {
  encodeUrl: true
  timeout: 0
}
