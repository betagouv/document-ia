meta {
  name: Execute Workflow Sync
  type: http
  seq: 2
}

post {
  url: {{server}}api/v1/workflows/{{workflow_id}}/execute-sync
  body: multipartForm
  auth: inherit
}

body:multipart-form {
  metadata: {"test":"test"} @contentType(String)
  file:
  extraction-parameters: {"document-type": "avis_imposition"}
  ~classification-parameters: {"document-types": ["cni", "passeport"]}
}

vars:pre-request {
  workflow_id: poc-embedding-classification
}

settings {
  encodeUrl: true
  timeout: 0
}
