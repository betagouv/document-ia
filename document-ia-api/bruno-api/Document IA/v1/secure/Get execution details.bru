meta {
  name: Get execution details
  type: http
  seq: 3
}

get {
  url: {{server}}api/v1/executions/{{execution_id}}?is_debug_mode=true
  body: none
  auth: apikey
}

params:query {
  is_debug_mode: true
}

auth:apikey {
  key: X-Api-Key
  value: {{admin-api-key}}
  placement: header
}

vars:pre-request {
  execution_id: a77c880d-b041-4e82-a58a-40a9e653620b
}

settings {
  encodeUrl: true
  timeout: 0
}
