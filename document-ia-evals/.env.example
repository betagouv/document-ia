# Example environment variables
# Copy this file to .env and update with your actual values

# Application Settings
APP_TITLE="Streamlit App"
DEBUG=false

# Label Studio Configuration (for Experiments page)
LABEL_STUDIO_URL=
LABEL_STUDIO_API_KEY=

DOCUMENT_IA_API_KEY=
DOCUMENT_IA_BASE_URL=

# API Keys (if needed)
# API_KEY=your_api_key_here

# Database Configuration
# PostgreSQL runs on port 5435 (not 5432) to avoid conflicts with system PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/experiments_db
DB_HOST=localhost
DB_PORT=5435
DB_NAME=experiments_db
DB_USER=postgres
DB_PASSWORD=postgres

# For Docker network connection (if running Streamlit in a container):
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/experiments_db
# DB_HOST=postgres
# DB_PORT=5432

# Other Settings
# MAX_UPLOAD_SIZE=200
