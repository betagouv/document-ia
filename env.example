BASE_URL=http://localhost:8000

# Configuration du serveur (optionnel)
HOST=0.0.0.0
PORT=8000

# Configuration PostgreSQL
POSTGRES_DB=document_ia
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_PORT=5555
POSTGRES_SSL_MODE=disable
# OR
POSTGRESQL_URL=

# Configuration Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# OR
REDIS_URL=

REDIS_WORKER_NUMBER=2

EVENT_CONSUMER_GROUP=document-ia-worker-workflow

# Configuration MinIO (S3 compatible, only for dev)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Configuration S3 Storage
S3_ENDPOINT_URL=http://localhost:${MINIO_API_PORT}
S3_ACCESS_KEY_ID=${MINIO_ROOT_USER}
S3_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
S3_BUCKET_NAME=document-ia
S3_REGION_NAME=us-east-1
S3_USE_SSL=false

# File Upload Configuration
MAX_FILE_SIZE=26214400  # 25MB in bytes

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS_PER_MINUTE=300
RATE_LIMIT_REQUESTS_PER_DAY=5000

# Database Migration Configuration
AUTO_MIGRATE=true  # Set to false to disable auto-migration

OPENAI_API_KEY= your-openai-api-key
OPENAI_BASE_URL= https://api.openai.com/v1

LOKI_LOGGING_ENABLED=true
LOKI_URL= your-loki-url
APP_ENV=dev

# Initial document ai admin organization api key
DOCUMENT_IA_API_KEY= your-document-ia-api-key

MARKER_API_KEY= marker-api-key
MARKER_BASE_URL= marker-base-url

WEBHOOK_SECRET_ENCRYPTION_KEY= webhook-secret-encryption-key
